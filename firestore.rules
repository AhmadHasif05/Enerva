rules_version = '2';

// RunTrack Firestore security rules (Phase 3 / plan.md §5.5).
//
// Model:
//  - A user's profile doc and every private sub-collection (follows, savedRoutes,
//    activities, media) are readable/writable ONLY by that user. Other users
//    cannot read your profile — display names needed for chat are denormalised
//    into the conversation doc instead (see participantNames below).
//  - Conversations are shared top-level docs; only listed participants may
//    read/write them. Messages inherit access from their parent conversation and
//    can't be spoofed (senderUid must match the caller) or edited after the fact.
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- users/{uid} (+ all sub-collections) — owner only ----
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ---- publicProfiles/{uid} — discovery directory ----
    // Any signed-in user can read (so Search finds people); only the owner writes
    // their own entry. Holds public fields only (name, photo, location, level).
    match /publicProfiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ---- publicReels/{mediaId} — cross-user Gallery feed ----
    // Any signed-in user can read; a reel can only be created/edited by its owner.
    match /publicReels/{mediaId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                            && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid;
    }

    // ---- conversations/{id} — participants only ----
    match /conversations/{conversationId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participants;
      // On create, `resource` doesn't exist yet — validate the incoming data.
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants;
      allow update, delete: if request.auth != null
                            && request.auth.uid in resource.data.participants;

      // ---- messages sub-collection ----
      match /messages/{messageId} {
        function parentParticipants() {
          return get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        }
        allow read: if request.auth != null
                    && request.auth.uid in parentParticipants();
        // A message can only be authored as yourself, in a conversation you're in.
        allow create: if request.auth != null
                      && request.auth.uid in parentParticipants()
                      && request.resource.data.senderUid == request.auth.uid;
        // Messages are immutable once sent.
        allow update, delete: if false;
      }
    }
  }
}
